{
    "compilerOptions": {
        /* Environment & Language */
        "target": "ESNext",
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ESNext"
        ],
        "useDefineForClassFields": true,
        "jsx": "react-jsx", // Required for .tsx files (New JSX transform)
        /* Module Resolution */
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "allowImportingTsExtensions": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        /* Type Checking */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "skipLibCheck": true,
        /* Output & Emit */
        "noEmit": true,
        /* Vite & Test Integration */
        "types": [
            "vite/client"
        ]
    },
    "include": [
        "src"
    ]
}